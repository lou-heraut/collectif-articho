
#footer {
    /* margin-left: 4rem;  */
    /* margin-right: 4rem; */
    margin-top: 1rem;
    margin-bottom: 2rem;
    font-family: Helvetica, Arial, sans-serif;
    font-size: 0.75rem;
    position: relative;
    bottom: 0px;
    left: 0px;
    height: 4rem;
    width: calc(100vw - 8rem);
    background: #fff;
    color: #151206;
}

#footer_social {
    position: absolute;
    right: 0px;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
}
#footer_social a {
    background-color: #ffffff;
    color: #818181;
    border: none;
    padding-left: 1rem;
    margin: 0;
    background-color: transparent;
    cursor: pointer;
    touch-action: manipulation;
    position: relative;
    display: inline-flex;
    flex-wrap: nowrap;
    align-items: center;
}

#footer_line {
    margin-top: 2rem;
    margin-bottom: 2rem;
    border: 0;
    border-top-width: 0px;
    border-top-style: none;
    border-top-color: currentcolor;
    border-top: 1px solid #ddd;
}

#footer_info {
    position: absolute;
    left: 0px;
    bottom: 0px;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
}
#footer_info a {
    background-color: #ffffff;
    color: #818181;
    border: none;
    min-width: 2rem;
    padding-right: 1rem;
    margin: 0;
    background-color: transparent;
    cursor: pointer;
    touch-action: manipulation;
    position: relative;
    display: inline-flex;
    flex-wrap: nowrap;
    align-items: center;
}
#footer_info a:focus {
    color: #818181;
    font-weight: normal;
}
#footer_info a:hover {
    color: #151206;
    font-weight: normal;
}

#footer_copyright {
    position: absolute;
    right: 0px;
    bottom: 0px;
}

